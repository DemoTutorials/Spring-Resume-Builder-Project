    <changeSet id="dev_001_qrtz_triggers" author="Avisys">
		<preConditions onFail="MARK_RAN">
			<not>
				<tableExists tableName="qrtz_triggers" />
			</not>
		</preConditions>
        <createTable tableName="qrtz_triggers">
            <column name="sched_name" type="varchar(120)">
				<constraints primaryKey="true" primaryKeyName="qrtz_triggers_pk"
					nullable="false" />
			</column>
            <column name="trigger_name" type="varchar(200)">
				<constraints primaryKey="true" primaryKeyName="qrtz_triggers_pk"
					nullable="false" />
			</column>
            <column name="trigger_group" type="varchar(200)">
				<constraints primaryKey="true" primaryKeyName="qrtz_triggers_pk"
					nullable="false" />
			</column>
            <column name="job_name" type="varchar(200)">
				<constraints nullable="false" />
			</column>
            <column name="job_group" type="varchar(200)">
				<constraints nullable="false" />
			</column>
			<column name="description" type="varchar(250)" />
			<column name="next_fire_time" type="int8" />
			<column name="prev_fire_time" type="int8" />
			<column name="priority" type="int4" />
            <column name="trigger_state" type="varchar(16)">
				<constraints nullable="false" />
			</column>
            <column name="trigger_type" type="varchar(8)">
				<constraints nullable="false" />
			</column>
            <column name="start_time" type="int8">
				<constraints nullable="false" />
			</column>
			<column name="end_time" type="int8" />
			<column name="calendar_name" type="varchar(200)" />
			<column name="misfire_instr" type="int2" />
			<column name="job_data" type="bytea" />
		</createTable>
        <sql>
	        DROP TRIGGER IF EXISTS on_delete_add_tgr ON qrtz_triggers;
	        CREATE TRIGGER on_delete_add_tgr AFTER DELETE ON qrtz_triggers FOR EACH ROW EXECUTE FUNCTION after_delete_data();
    	</sql>
		<sql>
	        DROP TRIGGER IF EXISTS on_insert_tgr ON qrtz_triggers;
	        CREATE TRIGGER on_insert_tgr AFTER INSERT ON qrtz_triggers FOR EACH ROW EXECUTE FUNCTION insert_data();
    	</sql>
        <sql>
	        DROP TRIGGER IF EXISTS on_update_tgr ON qrtz_triggers;
	        CREATE TRIGGER on_update_tgr AFTER UPDATE ON qrtz_triggers FOR EACH ROW EXECUTE FUNCTION update_data();
    	</sql>
		
